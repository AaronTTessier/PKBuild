<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
            <Grid>
                <Button Content="Hello World"/>
            </Grid>
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    <Style Selector="Grid">
         <Setter Property="Background" Value="#F3F3F3"/> 
    </Style>
    <Style Selector="Grid.Topbar">
        <Setter Property="Background" Value="{DynamicResource PrimaryTopbarBackground}"/>
    </Style>
    <Style Selector="Border.Topbar">
        <Setter Property="Background" Value="{DynamicResource PrimaryTopbarBackground}"/>
    </Style>
    <Style Selector="Button">
        <Setter Property="Background" Value="#CDCDCD"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#767676"/>
    </Style>
</Styles>
