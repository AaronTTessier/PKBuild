<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20" Background="White">
            <!-- Add Controls for Previewer Here -->
            <Slider Width="200">
                
            </Slider>
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    
    <Style Selector="Grid.Topbar">
        <Setter Property="Background" Value="{DynamicResource PrimaryTopbarBackground}"/>
    </Style>
    
    <Style Selector="Border.Topbar">
        <Setter Property="Background" Value="{DynamicResource PrimaryTopbarBackground}"/>
    </Style>
    
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryButton}"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonPointerOver}"/>
    </Style>
    
    <Style Selector="Button.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ActiveButton}"/>
        <Setter Property="Foreground" Value="{DynamicResource ActiveFont}"/>
    </Style>
    
    <Style Selector="ComboBox#ComboBoxPokemonNames">
        <Setter Property="Width" Value="200"/>
    </Style>
    <Style Selector="ComboBox#ComboBoxPokemon">
        <Setter Property="Width" Value="200"/>
    </Style>    
    
    <Style Selector="TextBox#UsernameLoginBox">
        <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#PasswordLoginBox">
        <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#UsernameLoginBox">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#UsernameLoginBox:focus">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#UsernameLoginBox:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#PasswordLoginBox">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#PasswordLoginBox:focus">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="TextBox#PasswordLoginBox:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    
    <Style Selector="ToggleButton:unchecked">
        <Setter Property="Background" Value="{DynamicResource PrimaryTopbarBackground}"/>
    </Style>
    
    <Style Selector="ToggleButton:pointerover /template/ ContentPresenter"> 
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextForeground}"/>
    </Style>
    

</Styles>
