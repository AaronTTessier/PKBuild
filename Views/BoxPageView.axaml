                                    000
                                </TextBlock>
                                <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="6" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
