                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Center">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Center">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Center">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Center">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Center">
                                    000
                                </TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
