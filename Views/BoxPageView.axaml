                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Center">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black" TextWrapping="Wrap"
