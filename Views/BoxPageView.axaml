                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black" TextWrapping="Wrap"
                                           HorizontalAlignment="Right">
                                    000
                                </TextBlock>
                                <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="6" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
