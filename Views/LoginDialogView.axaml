<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pkbvm="clr-namespace:PKBuild.ViewModels"
             x:DataType="pkbvm:LoginDialogViewModel"
             Background="Transparent"
             mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="650"
             x:Class="PKBuild.Views.LoginDialogView">
    <Design.DataContext><pkbvm:LoginDialogViewModel></pkbvm:LoginDialogViewModel></Design.DataContext>
    <DockPanel Margin="20">
        <!-- Top DockPanel Child -->
        <StackPanel DockPanel.Dock="Top" Width="200" Background="Blue">
            <TextBlock Text="{Binding DialogTitle}" Padding="20" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextForeground}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Message}" Padding="0 0 0 20" FontSize="15" Foreground="{DynamicResource PrimaryGridBackground}" HorizontalAlignment="Center"/> 
        </StackPanel>
        
        <!-- Bottom Dockpanel Child -->
        <StackPanel DockPanel.Dock="Bottom" Background="Green" Spacing="10">
            <TextBlock Text="{Binding ErrMessage}" IsVisible="{Binding HasError}" HorizontalAlignment="Center" Foreground="GreenYellow" FontSize="15"/>
            
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <Label>Login</Label>
            </Button>
            
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <Label>Register</Label>
            </Button>
            <Button HorizontalAlignment="Center" Height="30">
                <Label FontSize="10">Go Back</Label>
            </Button>
            
        </StackPanel>
        
        <!-- Undocked (Center) Child -->
        <StackPanel Background="Bisque">
            
        </StackPanel>
    </DockPanel>
    <!--<Border Background="{DynamicResource PrimaryGridBackground}" Margin="20" BorderBrush="{DynamicResource PrimaryTextForeground}" BorderThickness="5">
        <StackPanel>
            
            ~1~ PKBuild Login Title Start @1@
            <Border Background="{DynamicResource PrimaryTopbarBackground}">
