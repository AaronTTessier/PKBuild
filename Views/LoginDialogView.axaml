                    <TextBox Grid.Column="0" x:Name="PasswordLoginBox" Width="200" Watermark="Password" PasswordChar="*" Text="{Binding Password}"></TextBox>
                    <ToggleButton Grid.Column="1" Content="Reveal" IsChecked="{Binding #PasswordLoginBox.RevealPassword}"/>
                </Grid>
                
            </StackPanel>
            ~1~ PKBuild Login TextBoxes End @1@
            
            ~1~ PKBuild Login Buttons Start @1@
