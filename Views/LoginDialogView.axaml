                <TextBlock Text="{Binding Message}" Margin="0 0 0 20" FontSize="15" Foreground="{DynamicResource PrimaryGridBackground}" HorizontalAlignment="Center"/>
            </Border>
            ~1~ PKBuild Login Text End @1@
            
            ~1~ PKBuild Login TextBoxes Start @1@
