<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pkbvm="clr-namespace:PKBuild.ViewModels"
             x:DataType="pkbvm:LoginDialogViewModel"
             Background="Transparent"
             
             x:Class="PKBuild.Views.LoginDialogView">
    <Design.DataContext><pkbvm:LoginDialogViewModel></pkbvm:LoginDialogViewModel></Design.DataContext>
    
    <Border Background="{DynamicResource PrimaryGridBackground}" Margin="20" BorderBrush="{DynamicResource PrimaryTextForeground}" BorderThickness="5">
        <StackPanel>
            
            <!-- PKBuild Login Title Start -->
            <Border Background="{DynamicResource PrimaryTopbarBackground}">
                <TextBlock Text="{Binding DialogTitle}" Padding="20" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextForeground}" HorizontalAlignment="Center"/>
            </Border>
            <!-- PKBuild Login Title End -->
            
            <!-- PKBuild Login Text Start -->
            <Border Background="{DynamicResource PrimaryTopbarBackground}">
                <TextBlock Text="{Binding Message}" Margin="0 0 0 20" FontSize="15" Foreground="{DynamicResource PrimaryGridBackground}" HorizontalAlignment="Center"/>
            </Border>
            <!-- PKBuild Login Text End -->
            
            <!-- PKBuild Login TextBoxes Start -->
            <StackPanel Margin="20">
                <TextBlock Text="{Binding ErrMessage}" IsVisible="false"></TextBlock>
                <TextBox x:Name="UsernameLoginBox" Margin="0 10 " Width="200" Watermark="Username" Text="{Binding Username}"></TextBox>
                
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Grid.Column="0" x:Name="PasswordLoginBox" Width="200" Watermark="Password" PasswordChar="*" Text="{Binding Password}"></TextBox>
                    <ToggleButton Grid.Column="1" Content="Reveal" IsChecked="{Binding #PasswordLoginBox.RevealPassword}"/>
                </Grid>
                
            </StackPanel>
            <!-- PKBuild Login TextBoxes End -->
            
            <!-- PKBuild Login Buttons Start -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button>
                    <Label>Login</Label>
                </Button>
                
                <Button>
                    <Label>Register</Label>
                </Button>
            </StackPanel>
            
            <Border>
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                    <Button HorizontalAlignment="Center" Height="30" Command="{Binding CancelLoginCommand}">
                        <Label FontSize="10">Go Back</Label>
                    </Button>
                </StackPanel>
            </Border>
            <!-- PKBuild Login Buttons End -->
        </StackPanel>
    </Border>
</UserControl>
