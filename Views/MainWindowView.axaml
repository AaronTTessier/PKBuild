<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="1024"
        x:Class="PKBuild.MainWindowView"
        xmlns:pkbvm="clr-namespace:PKBuild.ViewModels"
        xmlns:pkbview="clr-namespace:PKBuild.Views"
        x:DataType="pkbvm:MainWindowViewModel"
        Title="PKBuild">
        
        <!--For Designer for viewing data bindings-->
        <Design.DataContext><pkbvm:MainWindowViewModel></pkbvm:MainWindowViewModel></Design.DataContext>
        
        <Grid>
                <!--Top Row-->
                <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
				
                        <Border Classes="Topbar" Padding="20">
                                <Grid Classes="Topbar" ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock TextAlignment="Center">PK-Build</TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <Button Content="Sign In"/>
                                                <Button Content="Register"/>
                                        </StackPanel>
                                </Grid>
                        </Border>
				
                </Grid>
		
                <!--Sidebar and Main Content-->
                <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
			
                        <!--SIDE BAR BEGIN-->
                        <Border Grid.Column="0" Padding="20">
                                <Grid RowDefinitions="*, Auto">
                                        <StackPanel Spacing="12">
                                                <Button x:Name="BoxesBtn" Height="50" HorizontalAlignment="Stretch" VerticalContentAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                                <Image Source="{SvgImage /Assets/Images/box.svg}" Width="25"/>
                                                                <Label Content="Boxes"></Label>
                                                        </StackPanel>
                                                </Button>
                                                
                                                <Button Height="50" HorizontalAlignment="Stretch" VerticalContentAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                                <Image Source="{SvgImage /Assets/Images/image.svg}" Width="25"/>
                                                                <Label Content="Pokemon"></Label>
                                                        </StackPanel>
                                                </Button>
                                                
                                                <Button Height="50" HorizontalAlignment="Stretch" VerticalContentAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                                <Image Source="{SvgImage /Assets/Images/briefcase.svg}" Width="25"/>
                                                                <Label Content="Items"></Label>
                                                        </StackPanel>
                                                </Button>
                                                <Button Height="50" HorizontalAlignment="Stretch" VerticalContentAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                                <Image Source="/Assets/Images/shield-64.png" Width="25"/>
                                                                <Label Content="Moves"></Label>
                                                        </StackPanel>
                                                </Button>
                                                <Button Height="50" Content="Teams" HorizontalAlignment="Stretch" VerticalContentAlignment="Center"/>
                                                <Button Height="50" Content="Analysis" HorizontalAlignment="Stretch" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Row="1" Height="50" Content="Settings" HorizontalAlignment="Stretch" VerticalContentAlignment="Center"/>
                                </Grid>
                        </Border>
                        
                        <!--SIDE BAR END-->
				
                        <!--MAIN CONTENT BEGIN-->
                        <ContentControl Grid.Column="1" Padding="20" Content="{Binding PkbCurrentPage}"/>
                        <!--MAIN CONTENT END-->
                </Grid>
        </Grid>
</Window>
