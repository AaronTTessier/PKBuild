<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:pkbvm="clr-namespace:PKBuild.ViewModels"
             x:DataType="pkbvm:SettingsPageViewModel"
             x:Class="PKBuild.Views.SettingsPageView">
    <Design.DataContext><pkbvm:SettingsPageViewModel></pkbvm:SettingsPageViewModel></Design.DataContext>
    <Label Content="{Binding BuildTest}"/>
</UserControl>
