<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             xmlns:pkbvm="clr-namespace:PKBuild.ViewModels"
             x:DataType="pkbvm:TeamsPageViewModel"
             x:Class="PKBuild.Views.TeamsPageView">
    <Design.DataContext>
        <pkbvm:TeamsPageViewModel></pkbvm:TeamsPageViewModel>
    </Design.DataContext>
    <Grid RowDefinitions="Auto, *, Auto">
        <StackPanel Grid.Row="0" Background="Gray">
            <Label x:Name="TeamNameLabel" FontSize="25" HorizontalAlignment="Center">Team Name</Label>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid RowDefinitions="*, *" ColumnDefinitions="*, *, *" Margin="0 0 0 5">
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5 5 5 0">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource PrimaryTopbarBackground}">
                            <Image Source="/Assets/Images/shield-64.png" Width="75" />

                            <TextBlock Foreground="White" HorizontalAlignment="Center" Margin="0 10">
                                Pokémon Alpha
                            </TextBlock>

                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*,*,*,*"
                                  Background="{DynamicResource PrimaryGridBackground}">
                                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="Black">Effort Values</TextBlock>
                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black">Total</TextBlock>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Black">HP:</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Black">ATK:</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Black">DEF:</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Black">SpA:</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="0" Foreground="Black">SpD:</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="0" Foreground="Black">SPE:</TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="Black">000</TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding ChangePokemonCommand}">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5 5 5 0">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource PrimaryTopbarBackground}">
                            <Image Source="/Assets/Images/shield-64.png" Width="75" />
                            <TextBlock Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0 10">
                                Pokémon Alpha
                            </TextBlock>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*,*,*,*"
                                  Background="{DynamicResource PrimaryGridBackground}">
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Black">HP:</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Black">ATK:</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Black">DEF:</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Black">SpA:</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="0" Foreground="Black">SpD:</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="0" Foreground="Black">SPE:</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="Black">Effort Values</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="Black">000</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black">Total</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding ChangePokemonCommand}">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="5 5 5 0">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource PrimaryTopbarBackground}">
                            <Image Source="/Assets/Images/shield-64.png" Width="75" />
                            <TextBlock Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0 10">
                                Pokémon Alpha
                            </TextBlock>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*,*,*,*"
                                  Background="{DynamicResource PrimaryGridBackground}">
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Black">HP:</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Black">ATK:</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Black">DEF:</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Black">SpA:</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="0" Foreground="Black">SpD:</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="0" Foreground="Black">SPE:</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="Black">Effort Values</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="Black">000</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black">Total</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding ChangePokemonCommand}">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5 5 5 5">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource PrimaryTopbarBackground}">
                            <Image Source="/Assets/Images/shield-64.png" Width="75" />
                            <TextBlock Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0 10">
                                Pokémon Alpha
                            </TextBlock>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*,*,*,*"
                                  Background="{DynamicResource PrimaryGridBackground}">
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Black">HP:</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Black">ATK:</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Black">DEF:</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Black">SpA:</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="0" Foreground="Black">SpD:</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="0" Foreground="Black">SPE:</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="Black">Effort Values</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="Black">000</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black">Total</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding ChangePokemonCommand}">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5 5 5 0">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource PrimaryTopbarBackground}">
                            <Image Source="/Assets/Images/shield-64.png" Width="75" />
                            <TextBlock Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0 10">
                                Pokémon Alpha
                            </TextBlock>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*,*,*,*"
                                  Background="{DynamicResource PrimaryGridBackground}">
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Black">HP:</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Black">ATK:</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Black">DEF:</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Black">SpA:</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="0" Foreground="Black">SpD:</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="0" Foreground="Black">SPE:</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="Black">Effort Values</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="Black">000</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black">Total</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding ChangePokemonCommand}">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="5 5 5 5">
                    <Border BorderBrush="Black" CornerRadius="3" BorderThickness="2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource PrimaryTopbarBackground}">
                            <Image Source="/Assets/Images/shield-64.png" Width="75" />
                            <TextBlock Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0 10">
                                Pokémon Foxtrot
                            </TextBlock>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*,*,*,*,*"
                                  Background="{DynamicResource PrimaryGridBackground}">
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Black">HP:</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Black">ATK:</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Black">DEF:</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Black">SpA:</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="0" Foreground="Black">SpD:</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="0" Foreground="Black">SPE:</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="Black">Effort Values</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="1" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="1" Foreground="Black">000</TextBlock>

                                <TextBlock Grid.Row="0" Grid.Column="2" Foreground="Black">Total</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="4" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="5" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <TextBlock Grid.Row="6" Grid.Column="2" Foreground="Black">000</TextBlock>
                                <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding ChangePokemonCommand}">
                                    <TextBlock>Edit Pokemon</TextBlock>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
        <StackPanel Grid.Row="2" Grid.Column="0">
            <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"
                    Height="50">
                <TextBlock>Edit Team</TextBlock>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>